# Example environment variables for Terminus Storage

# Storacha-related keys
STORACHA_PRINCIPAL_KEY=your-principal-key
STORACHA_SPACE_DID=your-space-did
STORACHA_PROOF=your-proof

# Solana network configuration
SOLANA_NETWORK=devnet

# Lit Protocol network configuration
LIT_NETWORK=datil-dev

# Node environment
NODE_ENV=development

# Test-related keys
TEST_EVM_PRIVATE_KEY=your-evm-private-key
TEST_VAULT_PDA=REPLACE_WITH_YOUR_VAULT_PDA
TEST_OWNER_SOLANA=REPLACE_WITH_OWNER_SOLANA_ADDRESS
TEST_VAULT_UNLOCKED=false